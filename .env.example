# Firebase Configuration (get from Firebase Console)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-ABCDEF1234

# Supabase Configuration (alternative to Firebase - get from supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# DeepSeek API (https://platform.deepseek.com/api_keys)
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Anthropic Claude API (optional)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube API (optional - for exercise video tutorials, get from console.cloud.google.com)
# To get a key: https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3 in your project
VITE_YOUTUBE_API_KEY=your_youtube_api_key

# Backend provider: "firebase" or "supabase" (default: firebase)
VITE_BACKEND_PROVIDER=firebase

# ==========================
# PRODUCTION SETUP CHECKLIST
# ==========================
# 1. Create Firebase project at https://console.firebase.google.com
# 2. Enable Email/Password authentication
# 3. Create Firestore database with these collections: users, workoutSessions
# 4. Get DeepSeek API key from https://platform.deepseek.com/api_keys
# 5. (Optional) Get Anthropic API key from https://console.anthropic.com
# 6. (Optional) Get YouTube API key for video tutorials
# 7. Add all environment variables to Vercel project settings
# 8. Deploy to Vercel: vercel --prod